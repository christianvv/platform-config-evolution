# Managed by Salt — do not edit by hand.
# srv/salt/source_control/templates/gitlab.rb.jinja

external_url '{{ pillar['gitlab']['external_url'] }}'

# Time zone
gitlab_rails['time_zone'] = '{{ pillar['gitlab']['timezone'] }}'

{% if pillar['gitlab']['smtp']['enable'] %}
gitlab_rails['smtp_enable'] = true
gitlab_rails['smtp_address'] = "{{ pillar['gitlab']['smtp']['address'] }}"
gitlab_rails['smtp_port'] = {{ pillar['gitlab']['smtp']['port'] }}
gitlab_rails['smtp_user_name'] = "{{ pillar['gitlab']['smtp']['user_name'] }}"
gitlab_rails['smtp_password'] = "{{ pillar['gitlab']['smtp']['password'] }}"
gitlab_rails['smtp_domain'] = "{{ pillar['gitlab']['smtp']['domain'] }}"
gitlab_rails['smtp_authentication'] = 'login'
gitlab_rails['smtp_enable_starttls_auto'] = true
{% else %}
gitlab_rails['smtp_enable'] = false
{% endif %}

# Local backup retention
gitlab_rails['backup_keep_time'] = {{ pillar['gitlab']['backup']['keep_time_seconds'] }}

# GitLab Runner registration happens on the dedicated CI/CD runner host
# (see cicd_runner/init.sls) — the Docker executor there registers against
# this instance's external_url, not against a runner running locally here.
